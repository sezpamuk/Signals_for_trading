def __init__(self, reference_date: datetime):
    self.reference_date = reference_date
    
    # Data storage
    self.bond_features: Dict[str, Dict] = {}
    self.spread_data: Dict[str, pd.DataFrame] = {}
    self.bonds_with_history: Set[str] = set()
    
    # ML Models
    self.xgb_similarity_model = None
    self.xgb_spread_ratio_model = None
    self.rf_similarity_model = None
    self.feature_scaler = StandardScaler()
    
    # Encoders for categorical features
    self.issuer_encoder = LabelEncoder()
    self.sector_encoder = LabelEncoder()
    self.rating_encoder = LabelEncoder()
    self.region_encoder = LabelEncoder()
    
    # Rating map for numeric conversion
    self.rating_map = {
        'AAA': 1, 'AA+': 2, 'AA': 3, 'AA-': 4,
        'A+': 5, 'A': 6, 'A-': 7,
        'BBB+': 8, 'BBB': 9, 'BBB-': 10,
        'BB+': 11, 'BB': 12, 'BB-': 13,
        'B+': 14, 'B': 15, 'B-': 16,
        'CCC+': 17, 'CCC': 18, 'CCC-': 19,
        'CC': 20, 'C': 21, 'D': 22
    }
    
    # Results storage
    self.final_mapping: Dict[str, ProxyResult] = {}
    self.training_history: Dict = {}

# ========================================================================
# DATA LOADING AND PREPROCESSING
# ========================================================================

def load_data(
    self,
    features_path: str,
    spreads_path: str,
    portfolio_path: str
):
    """
    Load all required data files
    
    Args:
        features_path: CSV with bond reference data (35K bonds)
        spreads_path: CSV with historical z-spreads (7K bonds)
        portfolio_path: CSV with portfolio bonds (10K bonds)
    """
    print("=" * 80)
    print("LOADING DATA")
    print("=" * 80)
    
    # Load files
    print("\n[1] Loading bond reference data...")
    features_df = pd.read_csv(features_path)
    print(f"    Loaded {len(features_df):,} bonds")
    
    print("\n[2] Loading historical spreads...")
    spreads_df = pd.read_csv(spreads_path)
    print(f"    Loaded {len(spreads_df):,} spread observations")
    
    print("\n[3] Loading portfolio...")
    portfolio_df = pd.read_csv(portfolio_path)
    print(f"    Loaded {len(portfolio_df):,} portfolio bonds")
    
    # Process bond features
    print("\n[4] Processing bond features...")
    for _, row in features_df.iterrows():
        isin = row['isin']
        
        maturity = pd.to_datetime(row['maturity_date'])
        issue = pd.to_datetime(row['issue_date'])
        tenor = (maturity - self.reference_date).days / 365.25
        
        self.bond_features[isin] = {
            'isin': isin,
            'issuer': str(row['issuer']),
            'sector': str(row['sector']),
            'rating': str(row['rating']),
            'rating_numeric': self.rating_map.get(str(row['rating']), 10.0),
            'region': str(row['region']),
            'currency': str(row['currency']),
            'seniority': str(row['seniority']),
            'tenor': tenor,
            'coupon': float(row['coupon']),
            'amount_outstanding': float(row['amount_outstanding']),
            'maturity_date': maturity,
            'issue_date': issue
        }
    
    # Process spread data
    print("\n[5] Processing spread data...")
    for isin in spreads_df['isin'].unique():
        bond_spreads = spreads_df[spreads_df['isin'] == isin].copy()
        bond_spreads['date'] = pd.to_datetime(bond_spreads['date'])
        bond_spreads = bond_spreads.sort_values('date')
        
        self.spread_data[isin] = bond_spreads
        self.bonds_with_history.add(isin)
    
    # Fit encoders
    print("\n[6] Fitting categorical encoders...")
    all_issuers = [f['issuer'] for f in self.bond_features.values()]
    all_sectors = [f['sector'] for f in self.bond_features.values()]
    all_ratings = [f['rating'] for f in self.bond_features.values()]
    all_regions = [f['region'] for f in self.bond_features.values()]
    
    self.issuer_encoder.fit(all_issuers)
    self.sector_encoder.fit(all_sectors)
    self.rating_encoder.fit(all_ratings)
    self.region_encoder.fit(all_regions)
    
    # Identify bonds needing proxies
    portfolio_isins = set(portfolio_df['isin'].tolist())
    self.bonds_needing_proxy = list(portfolio_isins - self.bonds_with_history)
    
    print(f"\n{'=' * 80}")
    print("DATA SUMMARY")
    print("=" * 80)
    print(f"Total bonds in database: {len(features_df):,}")
    print(f"Bonds with historical data: {len(self.bonds_with_history):,}")
    print(f"Portfolio size: {len(portfolio_df):,}")
    print(f"Bonds needing proxy: {len(self.bonds_needing_proxy):,}")
    print(f"  Coverage: {(1 - len(self.bonds_needing_proxy)/len(portfolio_df))*100:.1f}%")
    
    # Store for later
    self.portfolio_df = portfolio_df
    
    return self.bonds_needing_proxy

