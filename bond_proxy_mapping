def export_results(
    self,
    results_df: pd.DataFrame,
    base_path: str = 'best_proxy_results'
):
    """Export results to multiple files"""
    print("\n" + "=" * 80)
    print("EXPORTING RESULTS")
    print("=" * 80)
    
    # 1. Complete results
    complete_file = f'{base_path}_complete.csv'
    results_df.to_csv(complete_file, index=False)
    print(f"\n[1] Complete results: {complete_file}")
    print(f"    Columns: {len(results_df.columns)}")
    print(f"    Rows: {len(results_df):,}")
    
    # 2. Summary (key columns only)
    summary_cols = [
        'target_isin', 'target_issuer', 'target_rating', 'target_sector', 'target_tenor',
        'proxy_isin', 'proxy_issuer', 'proxy_rating', 'proxy_sector', 'proxy_tenor',
        'match_level', 'confidence_score', 'spread_ratio',
        'same_issuer', 'same_sector', 'tenor_difference'
    ]
    summary_df = results_df[summary_cols]
    summary_file = f'{base_path}_summary.csv'
    summary_df.to_csv(summary_file, index=False)
    print(f"\n[2] Summary: {summary_file}")
    
    # 3. Explanations
    explanations_df = results_df[['target_isin', 'proxy_isin', 'match_level', 'confidence_score', 'explanation']]
    explanations_file = f'{base_path}_explanations.csv'
    explanations_df.to_csv(explanations_file, index=False)
    print(f"\n[3] Explanations: {explanations_file}")
    
    # 4. Low confidence bonds (for manual review)
    low_confidence = results_df[results_df['confidence_score'] < 60.0]
    if len(low_confidence) > 0:
        review_file = f'{base_path}_low_confidence_review.csv'
        low_confidence.to_csv(review_file, index=False)
        print(f"\n[4] Low confidence bonds: {review_file}")
        print(f"    {len(low_confidence):,} bonds need manual review (confidence < 60%)")
    
    # 5. Quality metrics
    metrics = {
        'total_bonds_mapped': len(results_df),
        'avg_confidence': results_df['confidence_score'].mean(),
        'median_confidence': results_df['confidence_score'].median(),
        'same_issuer_pct': results_df['same_issuer'].mean() * 100,
        'same_sector_pct': results_df['same_sector'].mean() * 100,
        'avg_tenor_diff': results_df['tenor_difference'].mean(),
        'model_similarity_r2': self.training_history.get('similarity_r2', 'N/A'),
        'model_spread_ratio_r2': self.training_history.get('spread_ratio_r2', 'N/A')
    }
    
    metrics_df = pd.DataFrame([metrics]).T
    metrics_df.columns = ['Value']
    metrics_file = f'{base_path}_quality_metrics.csv'
    metrics_df.to_csv(metrics_file)
    print(f"\n[5] Quality metrics: {metrics_file}")
    
    print("\n" + "=" * 80)
    print("EXPORT COMPLETE")
    print("=" * 80)

def print_sample_explanations(self, results_df: pd.DataFrame, n: int = 5):
    """Print sample explanations"""
    print("\n" + "=" * 80)
    print(f"SAMPLE EXPLANATIONS (showing {n} examples)")
    print("=" * 80)
    
    # Show diverse examples
    samples = []
    
    # High confidence
    high = results_df[results_df['confidence_score'] >= 85].head(1)
    if len(high) > 0:
        samples.append(('HIGH CONFIDENCE EXAMPLE', high.iloc[0]))
    
    # Medium confidence
    med = results_df[
        (results_df['confidence_score'] >= 70) &
        (results_df['confidence_score'] < 85)
    ].head(1)
    if len(med) > 0:
        samples.append(('MEDIUM CONFIDENCE EXAMPLE', med.iloc[0]))
    
    # ML-based
    ml = results_df[results_df['match_level'] == ProxyMatchLevel.ML_PREDICTION.value].head(1)
    if len(ml) > 0:
        samples.append(('ML-BASED EXAMPLE', ml.iloc[0]))
    
    # Low confidence
    low = results_df[results_df['confidence_score'] < 70].head(1)
    if len(low) > 0:
        samples.append(('LOW CONFIDENCE EXAMPLE (REVIEW NEEDED)', low.iloc[0]))
    
    for i, (title, row) in enumerate(samples[:n]):
        print(f"\n{'=' * 80}")
        print(f"Example {i+1}: {title}")
        print('=' * 80)
        print(f"\nTarget: {row['target_isin']}")
        print(f"  Issuer: {row['target_issuer']}")
        print(f"  Rating: {row['target_rating']}")
        print(f"  Sector: {row['target_sector']}")
        print(f"  Tenor: {row['target_tenor']:.1f} years")
        
        print(f"\nProxy: {row['proxy_isin']}")
        print(f"  Issuer: {row['proxy_issuer']}")
        print(f"  Rating: {row['proxy_rating']}")
        print(f"  Sector: {row['proxy_sector']}")
        print(f"  Tenor: {row['proxy_tenor']:.1f} years")
        
        print(f"\nMatch Quality:")
        print(f"  Level: {row['match_level']}")
        print(f"  Confidence: {row['confidence_score']:.1f}%")
        print(f"  Spread Ratio: {row['spread_ratio']:.2f}x")
        print(f"  Same Issuer: {'✓' if row['same_issuer'] else '✗'}")
        print(f"  Same Sector: {'✓' if row['same_sector'] else '✗'}")
        print(f"  Tenor Diff: {row['tenor_difference']:.2f} years")
        
        print(f"\nExplanation:")
        print(f"  {row['explanation']}")
