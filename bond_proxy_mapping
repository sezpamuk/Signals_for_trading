def generate_training_data(
    self,
    max_pairs: int = 10000,
    min_overlap: int = 20
) -> pd.DataFrame:
    """
    Generate training pairs from bonds with overlapping spread history
    
    Args:
        max_pairs: Maximum number of training pairs to generate
        min_overlap: Minimum overlapping observations required
        
    Returns:
        DataFrame with training pairs
    """
    print("\n" + "=" * 80)
    print("GENERATING TRAINING DATA")
    print("=" * 80)
    
    training_records = []
    bonds_list = list(self.bonds_with_history)
    
    print(f"\nGenerating pairs from {len(bonds_list):,} bonds with history...")
    print(f"Target: {max_pairs:,} training pairs")
    
    for i, isin1 in enumerate(bonds_list):
        if len(training_records) >= max_pairs:
            break
        
        if i % 100 == 0 and i > 0:
            print(f"  Progress: {i:,}/{len(bonds_list):,} bonds processed, "
                  f"{len(training_records):,} pairs generated...")
        
        # Limit comparisons for performance
        for isin2 in bonds_list[i+1:min(i+100, len(bonds_list))]:
            if len(training_records) >= max_pairs:
                break
            
            # Get spread data
            spreads1 = self.spread_data[isin1]
            spreads2 = self.spread_data[isin2]
            
            # Find overlapping dates
            dates1 = set(spreads1['date'])
            dates2 = set(spreads2['date'])
            common_dates = dates1 & dates2
            
            if len(common_dates) < min_overlap:
                continue
            
            # Calculate correlation and spread ratio
            common_dates_list = sorted(list(common_dates))
            
            spread1_series = spreads1.set_index('date')['z_spread']
            spread2_series = spreads2.set_index('date')['z_spread']
            
            spread1_common = spread1_series.loc[common_dates_list]
            spread2_common = spread2_series.loc[common_dates_list]
            
            correlation = spread1_common.corr(spread2_common)
            spread_ratio = (spread1_common / spread2_common).median()
            
            if np.isnan(correlation) or np.isnan(spread_ratio):
                continue
            
            # Clip extreme values
            correlation = max(0.0, min(1.0, correlation))
            spread_ratio = max(0.5, min(2.0, spread_ratio))
            
            # Get bond features
            feat1 = self.bond_features[isin1]
            feat2 = self.bond_features[isin2]
            
            # Create training record
            record = {
                # Bond 1 features
                'bond1_isin': isin1,
                'bond1_issuer': feat1['issuer'],
                'bond1_sector': feat1['sector'],
                'bond1_rating': feat1['rating'],
                'bond1_rating_num': feat1['rating_numeric'],
                'bond1_region': feat1['region'],
                'bond1_tenor': feat1['tenor'],
                'bond1_coupon': feat1['coupon'],
                'bond1_size': feat1['amount_outstanding'],
                
                # Bond 2 features
                'bond2_isin': isin2,
                'bond2_issuer': feat2['issuer'],
                'bond2_sector': feat2['sector'],
                'bond2_rating': feat2['rating'],
                'bond2_rating_num': feat2['rating_numeric'],
                'bond2_region': feat2['region'],
                'bond2_tenor': feat2['tenor'],
                'bond2_coupon': feat2['coupon'],
                'bond2_size': feat2['amount_outstanding'],
                
                # Derived features
                'same_issuer': 1.0 if feat1['issuer'] == feat2['issuer'] else 0.0,
                'same_sector': 1.0 if feat1['sector'] == feat2['sector'] else 0.0,
                'same_rating': 1.0 if feat1['rating'] == feat2['rating'] else 0.0,
                'same_region': 1.0 if feat1['region'] == feat2['region'] else 0.0,
                'rating_diff': abs(feat1['rating_numeric'] - feat2['rating_numeric']),
                'tenor_diff': abs(feat1['tenor'] - feat2['tenor']),
                'coupon_diff': abs(feat1['coupon'] - feat2['coupon']),
                'size_ratio': np.log1p(feat1['amount_outstanding']) / np.log1p(feat2['amount_outstanding']),
                
                # Targets
                'correlation': correlation,
                'spread_ratio': spread_ratio,
                'num_observations': len(common_dates)
            }
            
            training_records.append(record)
    
    df = pd.DataFrame(training_records)
    
    print(f"\n{'=' * 80}")
    print(f"Generated {len(df):,} training pairs")
    print(f"  Same issuer pairs: {df['same_issuer'].sum():,.0f} ({df['same_issuer'].mean()*100:.1f}%)")
    print(f"  Same sector pairs: {df['same_sector'].sum():,.0f} ({df['same_sector'].mean()*100:.1f}%)")
    print(f"  Average correlation: {df['correlation'].mean():.3f}")
    print(f"  Average spread ratio: {df['spread_ratio'].mean():.3f}")
    
    return df

