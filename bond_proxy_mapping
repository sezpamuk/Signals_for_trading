def train_models(self, training_data: pd.DataFrame):
    """
    Train all ML models
    
    Args:
        training_data: DataFrame with training pairs
    """
    print("\n" + "=" * 80)
    print("TRAINING ML MODELS")
    print("=" * 80)
    
    # Prepare features
    feature_cols = [
        'same_issuer', 'same_sector', 'same_rating', 'same_region',
        'rating_diff', 'tenor_diff', 'coupon_diff', 'size_ratio',
        'bond1_rating_num', 'bond2_rating_num',
        'bond1_tenor', 'bond2_tenor'
    ]
    
    X = training_data[feature_cols].values
    y_similarity = training_data['correlation'].values
    y_spread_ratio = training_data['spread_ratio'].values
    
    # Split data
    X_train, X_test, y_sim_train, y_sim_test, y_ratio_train, y_ratio_test = train_test_split(
        X, y_similarity, y_spread_ratio,
        test_size=0.2,
        random_state=42
    )
    
    # Scale features
    X_train_scaled = self.feature_scaler.fit_transform(X_train)
    X_test_scaled = self.feature_scaler.transform(X_test)
    
    # Train XGBoost models (best performance)
    print("\n[1] Training XGBoost Similarity Model...")
    if XGBOOST_AVAILABLE:
        self.xgb_similarity_model = XGBRegressor(
            n_estimators=200,
            max_depth=6,
            learning_rate=0.05,
            subsample=0.8,
            colsample_bytree=0.8,
            random_state=42,
            n_jobs=-1
        )
    else:
        self.xgb_similarity_model = GradientBoostingRegressor(
            n_estimators=200,
            max_depth=6,
            learning_rate=0.05,
            subsample=0.8,
            random_state=42
        )
    
    self.xgb_similarity_model.fit(X_train_scaled, y_sim_train)
    
    # Evaluate
    y_sim_pred = self.xgb_similarity_model.predict(X_test_scaled)
    sim_r2 = r2_score(y_sim_test, y_sim_pred)
    sim_mae = mean_absolute_error(y_sim_test, y_sim_pred)
    
    print(f"    R² Score: {sim_r2:.4f}")
    print(f"    MAE: {sim_mae:.4f}")
    
    # Train spread ratio model
    print("\n[2] Training XGBoost Spread Ratio Model...")
    if XGBOOST_AVAILABLE:
        self.xgb_spread_ratio_model = XGBRegressor(
            n_estimators=200,
            max_depth=6,
            learning_rate=0.05,
            subsample=0.8,
            colsample_bytree=0.8,
            random_state=42,
            n_jobs=-1
        )
    else:
        self.xgb_spread_ratio_model = GradientBoostingRegressor(
            n_estimators=200,
            max_depth=6,
            learning_rate=0.05,
            subsample=0.8,
            random_state=42
        )
    
    self.xgb_spread_ratio_model.fit(X_train_scaled, y_ratio_train)
    
    # Evaluate
    y_ratio_pred = self.xgb_spread_ratio_model.predict(X_test_scaled)
    ratio_r2 = r2_score(y_ratio_test, y_ratio_pred)
    ratio_mae = mean_absolute_error(y_ratio_test, y_ratio_pred)
    
    print(f"    R² Score: {ratio_r2:.4f}")
    print(f"    MAE: {ratio_mae:.4f}")
    
    # Train Random Forest for feature importance
    print("\n[3] Training Random Forest Model...")
    self.rf_similarity_model = RandomForestRegressor(
        n_estimators=100,
        max_depth=10,
        random_state=42,
        n_jobs=-1
    )
    
    self.rf_similarity_model.fit(X_train_scaled, y_sim_train)
    
    rf_r2 = self.rf_similarity_model.score(X_test_scaled, y_sim_test)
    print(f"    R² Score: {rf_r2:.4f}")
    
    # Feature importance
    print("\n[4] Feature Importance (XGBoost):")
    if XGBOOST_AVAILABLE:
        importance = self.xgb_similarity_model.feature_importances_
    else:
        importance = self.xgb_similarity_model.feature_importances_
    
    feature_importance = sorted(
        zip(feature_cols, importance),
        key=lambda x: x[1],
        reverse=True
    )
    
    for feat, imp in feature_importance[:8]:
        print(f"    {feat:20s}: {imp:.4f}")
    
    # Store training history
    self.training_history = {
        'similarity_r2': sim_r2,
        'similarity_mae': sim_mae,
        'spread_ratio_r2': ratio_r2,
        'spread_ratio_mae': ratio_mae,
        'rf_r2': rf_r2,
        'feature_importance': dict(feature_importance)
    }
    
    print("\n" + "=" * 80)
    print("MODEL TRAINING COMPLETE")
    print("=" * 80)

