        group = cls.get_factor_group(factor_name)
        return cls.GROUPS[group]['hedge_type'] if group else None


class FactorPreprocessor:
    """
    Standardize mixed-unit factors into comparable units.
    Critical prerequisite for any collinearity treatment.
    """
    
    def __init__(self, taxonomy: FactorTaxonomy):
        self.taxonomy = taxonomy
        self.scalers  = {}
    
    def fit_transform(self, 
                      raw_factors: pd.DataFrame) -> pd.DataFrame:
        
        processed = pd.DataFrame(index=raw_factors.index)
        
        for group_name, group_info in FactorTaxonomy.GROUPS.items():
            available = [f for f in group_info['factors'] 
                        if f in raw_factors.columns]
            if not available:
                continue
            
            unit = group_info['unit']
            
            for factor in available:
                series = raw_factors[factor].copy()
                
                if unit == 'bps_change':
                    # Already in bps changes — just use as-is
                    processed[factor] = series
                    
                elif unit == 'pct_return':
                    # Convert to decimal returns if not already
                    if series.abs().max() > 1:
                        processed[factor] = series / 100
                    else:
                        processed[factor] = series
                        
                elif unit == 'pct_change':
                    processed[factor] = series
            
        # Z-score everything for comparability
        # Store scalers for out-of-sample transform
        self.scaler = StandardScaler()
        scaled_vals = self.scaler.fit_transform(processed.dropna())
        
        result = pd.DataFrame(
            scaled_vals,
            index=processed.dropna().index,
            columns=processed.columns
        )
        
        print(f"Preprocessed {len(result.columns)} factors, "
              f"{len(result)} observations")
        
        return result
class WithinGroupOrthogonalizer:
    """
    First pass: resolve collinearity WITHIN each factor group.
    CDX_IG_5Y vs CDX_IG_7Y is pure redundancy — clean it here
    before dealing with cross-group relationships.
    
    Method: Keep most liquid/representative factor per group,
    residualize others against it.
    """
    
    # Most liquid/representative factor per group
    GROUP_ANCHORS = {
        'rates_level':      'UST_10Y',
        'rates_curve':      'SLOPE_2_10',
        'credit_ig':        'CDX_IG_5Y',
        'credit_hy':        'CDX_HY_5Y',
        'credit_em':        'CDX_EM_5Y',
        'equity_broad':     'SPX',
        'equity_vol':       'VIX',
        'equity_sector':    None,   # keep all sectors, different exposures
        'fx_dxy':           'DXY',
        'fx_em':            None,   # keep EM FX, different countries
        'commodity_energy': 'OIL_WTI',
        'commodity_metals': 'GOLD',
    }
    
    def __init__(self):
        self.residual_models = {}
        self.dropped_factors = {}
        self.anchor_factors  = {}
    
    def fit_transform(self, 
                      factors: pd.DataFrame,
                      r2_drop_threshold: float = 0.90) -> pd.DataFrame:
        """
        Within each group:
        1. Keep the anchor factor unchanged
        2. Regress all others on the anchor
        3. If R² > threshold → drop (redundant)
        4. Otherwise → keep residual (independent component)
        """
        
        result = pd.DataFrame(index=factors.index)
        
        for group_name, group_info in FactorTaxonomy.GROUPS.items():
            available = [f for f in group_info['factors'] 
                        if f in factors.columns]
            
            if not available:
                continue
            
            anchor = self.GROUP_ANCHORS.get(group_name)
            
            if anchor is None or anchor not in available:
                # No anchor — keep all factors as-is
                for f in available:
                    result[f] = factors[f]
                continue
            
            # Keep anchor unchanged
            result[f'{anchor}'] = factors[anchor]
            self.anchor_factors[group_name] = anchor
            
            dropped  = []
            kept     = [anchor]
            
            for factor in available:
                if factor == anchor:
                    continue
                
                # Regress factor on anchor
                X = factors[anchor].values.reshape(-1, 1)
                y = factors[factor].values
                
                valid = ~(np.isnan(X.flatten()) | np.isnan(y))
                X_v, y_v = X[valid], y[valid]
                
                coeffs = np.linalg.lstsq(
                    np.column_stack([X_v, np.ones(len(X_v))]),
                    y_v, rcond=None)[0]
                
                y_pred = X_v * coeffs[0] + coeffs[1]
                residual = y_v - y_pred
                
                r2 = 1 - np.var(residual) / (np.var(y_v) + 1e-12)
                
                if r2 > r2_drop_threshold:
                    # Near-redundant: drop it
                    dropped.append(factor)
                else:
                    # Has independent information: keep residual
                    resid_full = np.full(len(factors), np.nan)
                    resid_full[valid] = residual
                    result[f'{factor}_resid'] = resid_full
                    kept.append(f'{factor}_resid')
                    self.residual_models[factor] = coeffs
            
            self.dropped_factors[group_name] = dropped
            
            if dropped:
                print(f"{group_name}: dropped {dropped} "
                      f"(R²>{r2_drop_threshold:.0%} on anchor)")
        
        print(f"\nAfter within-group orthogonalization:")
        print(f"  Input factors:  {factors.shape[1]}")
        print(f"  Output factors: {result.shape[1]}")
        
        return result.dropna(axis=1, how='all')
class CrossGroupCollinearityResolver:
    """
    After within-group cleaning, you still have cross-group 
    collinearity: VIX vs CDX_HY, SPX vs CDX_IG, Oil vs EM FX.
    
    These aren't redundant — they carry different information —
    but their shared variance confuses regression-based methods.
    
    Solution: Sparse Factor Model that explicitly separates
    systematic (shared) from idiosyncratic (group-specific) variance.
    """
    
    def __init__(self, n_systematic_factors: int = 5):
        """
        n_systematic_factors: number of latent systematic factors
        to extract. Usually 3-6 for a macro factor universe:
        - Factor 1: Risk-On / Risk-Off (loads on everything)
        - Factor 2: Rates level
        - Factor 3: Credit spread level
        - Factor 4: EM vs DM
        - Factor 5: Energy/commodity
        """
        self.n_sys = n_systematic_factors
        self.fa    = FactorAnalysis(
            n_components=n_systematic_factors,
            rotation='varimax',      # varimax rotation for interpretability
            max_iter=1000
        )
    
    def fit_transform(self, 
                      factors: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
        """
        Returns:
        - systematic_factors: (T, n_sys) latent common factors
        - idiosyncratic_factors: (T, n_original) group-specific residuals
        
        Use both in downstream analysis — systematic for broad 
        macro hedging, idiosyncratic for specific risk pockets.
        """
        
        X = factors.dropna().values
        
        # Fit factor analysis
        sys_factors = self.fa.fit_transform(X)
        
        # Idiosyncratic = residual after removing systematic
        loadings     = self.fa.components_.T   # (n_factors, n_sys)
        X_hat        = sys_factors @ self.fa.components_
        idiosyncratic = X - X_hat
        
        # Label systematic factors by their dominant loadings
        loading_df   = pd.DataFrame(
            loadings, 
            index=factors.columns,
            columns=[f'SYS_{i+1}' for i in range(self.n_sys)]
        )
        
        sys_names = self._label_systematic_factors(loading_df)
        
        sys_df = pd.DataFrame(
            sys_factors,
            index=factors.dropna().index,
            columns=sys_names
        )
        
        idio_df = pd.DataFrame(
            idiosyncratic,
            index=factors.dropna().index,
            columns=[f'{c}_idio' for c in factors.columns]
        )
        
        print("\nSystematic Factor Loadings (top 3 per factor):")
        for sys_name in sys_names:
            top3 = loading_df[sys_name.replace(
                'SYS_', 'SYS_').replace('_', ' ')
            ].abs().nlargest(3) if sys_name in loading_df.columns \
                else loading_df.iloc[:, 0].abs().nlargest(3)
            print(f"  {sys_name}: {top3.index.tolist()}")
        
        self.loading_df = loading_df
        self.sys_names  = sys_names
        
        return sys_df, idio_df
    
    def _label_systematic_factors(self, 
                                   loading_df: pd.DataFrame) -> List[str]:
        """
        Auto-label systematic factors by their dominant loadings.
        Pure interpretability — doesn't change the math.
        """
        labels = []
        for col in loading_df.columns:
            dominant = loading_df[col].abs().idxmax()
            group    = FactorTaxonomy.get_factor_group(
                dominant.replace('_resid', '').replace('_idio', ''))
            label = f"SYS_{group or col}"
            labels.append(label)
        return labels
class BondFactorSelector:
    """
    For each bond (or cluster), identify the most significant 
    factors from the cleaned set using multiple complementary methods.
    
    No single method is sufficient:
    - LASSO: linear, fast, interpretable
    - Elastic Net: handles correlated survivors better than LASSO  
    - SHAP + LightGBM: captures non-linear effects
    - Mutual Information: model-free, catches any relationship
    - Granger Causality: directional, time-aware
    
    We combine signals across methods for robustness.
    """
    
    def __init__(self, min_observations: int = 100,
                       cv_folds: int = 5,
                       max_factors_per_bond: int = 8):
        
        self.min_obs       = min_observations
        self.cv_folds      = cv_folds
        self.max_factors   = max_factors_per_bond
        self.tscv          = TimeSeriesSplit(n_splits=cv_folds)
    
    # ----------------------------------------------------------------
    # Method 1: LASSO with cross-validated alpha
    # ----------------------------------------------------------------
    def lasso_selection(self, X: np.ndarray, y: np.ndarray,
                         feature_names: List[str]) -> pd.Series:
        """
        LASSO drives irrelevant coefficients exactly to zero.
        Cross-validated alpha prevents under/over-regularization.
        Returns normalized importance scores.
        """
        
        model = LassoCV(
            cv=self.tscv, 
            max_iter=5000,
            n_alphas=50,
            fit_intercept=True
        )
        
        try:
            model.fit(X, y)
            importance = np.abs(model.coef_)
        except Exception:
            return pd.Series(0.0, index=feature_names)
        
        return pd.Series(importance, index=feature_names)
    
    # ----------------------------------------------------------------
    # Method 2: Elastic Net (handles correlated factor groups better)
    # ----------------------------------------------------------------
    def elastic_net_selection(self, X: np.ndarray, y: np.ndarray,
                               feature_names: List[str]) -> pd.Series:
        """
        ElasticNet combines L1 (sparsity) and L2 (grouped selection).
        When two factors are correlated, ElasticNet tends to keep both
        with smaller coefficients rather than arbitrarily zeroing one.
        Better than pure LASSO for correlated credit factors.
        """
        
        model = ElasticNetCV(
            l1_ratio=[0.1, 0.3, 0.5, 0.7, 0.9],
            cv=self.tscv,
            max_iter=5000,
            fit_intercept=True
        )
        
        try:
            model.fit(X, y)
            importance = np.abs(model.coef_)
        except Exception:
            return pd.Series(0.0, index=feature_names)
        
        return pd.Series(importance, index=feature_names)
    
    # ----------------------------------------------------------------
    # Method 3: SHAP values from LightGBM
    # ----------------------------------------------------------------
    def shap_selection(self, X: np.ndarray, y: np.ndarray,
                        feature_names: List[str]) -> pd.Series:
        """
        SHAP gives model-agnostic feature importance that:
        - Captures non-linear relationships
        - Handles interactions between factors
        - Is theoretically grounded (Shapley values)
        
        Key advantage: doesn't suffer from collinearity
        distortion in the same way regression does.
        """
        
        model = lgb.LGBMRegressor(
            n_estimators=200,
            learning_rate=0.05,
            num_leaves=20,          # small trees to prevent overfit
            reg_lambda=1.0,
            reg_alpha=0.1,
            subsample=0.8,
            colsample_bytree=0.7,
            min_child_samples=20,
            verbose=-1
        )
        
        try:
            model.fit(X, y)
            explainer   = shap.TreeExplainer(model)
            shap_values = explainer.shap_values(X)
            
            # Mean absolute SHAP value per feature
            importance = np.abs(shap_values).mean(axis=0)
        except Exception:
            return pd.Series(0.0, index=feature_names)
        
        return pd.Series(importance, index=feature_names)
    
    # ----------------------------------------------------------------
    # Method 4: Mutual Information (model-free)
    # ----------------------------------------------------------------
    def mutual_info_selection(self, X: np.ndarray, y: np.ndarray,
                               feature_names: List[str]) -> pd.Series:
        """
        Mutual information makes no linearity assumptions.
        Catches any statistical dependence between factor and spread.
        Robust to outliers and heavy tails (common in credit).
        """
        
        try:
            # Use k-nearest neighbor estimator (robust, no distributional assumption)
            mi_scores = mutual_info_regression(
                X, y, 
                discrete_features=False,
                n_neighbors=5,
                random_state=42
            )
        except Exception:
            return pd.Series(0.0, index=feature_names)
        
        return pd.Series(mi_scores, index=feature_names)
    
    # ----------------------------------------------------------------
    # Method 5: Partial Least Squares — designed for collinear X
    # ----------------------------------------------------------------
    def pls_selection(self, X: np.ndarray, y: np.ndarray,
                      feature_names: List[str]) -> pd.Series:
        """
        PLS finds directions in X that maximally covary with y.
        Unlike PCA (which ignores y), PLS finds factors that are
        both (a) common in X and (b) predictive of y.
        
        Perfect for the collinear credit factor problem because
        it projects out the collinear structure while keeping
        only y-relevant variance.
        """
        
        n_components = min(5, X.shape[1], len(y) // 10)
        
        try:
            pls = PLSRegression(n_components=n_components, scale=True)
            pls.fit(X, y.reshape(-1, 1))
            
            # VIP (Variable Importance in Projection) scores
            # VIP > 1 → factor contributes above-average to PLS model
            t     = pls.x_scores_          # (n, n_components)
            w     = pls.x_weights_          # (n_features, n_components)
            q     = pls.y_loadings_         # (1, n_components)
            
            ss    = np.sum(t**2, axis=0) * np.sum(q**2, axis=0)
            vip   = np.sqrt(X.shape[1] * np.sum(
                w**2 * ss, axis=1) / np.sum(ss))
        except Exception:
            return pd.Series(0.0, index=feature_names)
        
        return pd.Series(vip, index=feature_names)
    
    # ----------------------------------------------------------------
    # Method 6: Granger Causality (time-aware)
    # ----------------------------------------------------------------
    def granger_selection(self, factor_df: pd.DataFrame,
                           spread_series: pd.Series,
                           max_lag: int = 5) -> pd.Series:
        """
        Tests whether each factor Granger-causes spread changes.
        Important for liquid factors (CDX) which often lead cash bonds.
        """
        from statsmodels.tsa.stattools import grangercausalitytests
        
        scores = {}
        
        for factor in factor_df.columns:
            try:
                data = pd.concat([spread_series, factor_df[factor]], 
                                  axis=1).dropna()
                
                if len(data) < max_lag * 10:
                    scores[factor] = 0.0
                    continue
                
                # Test at each lag, take min p-value
                results  = grangercausalitytests(
                    data.values, maxlag=max_lag, verbose=False)
                min_pval = min(
                    results[lag][0]['ssr_ftest'][1] 
                    for lag in range(1, max_lag + 1)
                )
                
                # Convert p-value to importance score (1 - p)
                scores[factor] = 1 - min_pval
                
            except Exception:
                scores[factor] = 0.0
        
        return pd.Series(scores)
    
    # ----------------------------------------------------------------
    # Ensemble: Combine all methods
    # ----------------------------------------------------------------
    def select_factors(self, 
                        X_df: pd.DataFrame,
                        y: pd.Series,
                        bond_metadata: dict = None) -> dict:
        """
        Run all selection methods and combine into a robust ranking.
        
        The ensemble logic:
        - Normalize each method's scores to [0,1]
        - Weight methods by their cross-validated predictive power
        - Apply economic constraints based on bond type
        - Return ranked factor list with confidence scores
        """
        
        feature_names = X_df.columns.tolist()
        
        # Align and validate
        aligned = pd.concat([X_df, y], axis=1).dropna()
        if len(aligned) < self.min_obs:
            warnings.warn(f"Insufficient data: {len(aligned)} obs")
            return {}
        
        X = aligned.iloc[:, :-1].values
        y_vals = aligned.iloc[:, -1].values
        
        print(f"  Running factor selection: "
              f"{X.shape[1]} factors, {X.shape[0]} obs")
        
        # Run all methods
        scores = {}
        scores['lasso']    = self.lasso_selection(X, y_vals, feature_names)
        scores['enet']     = self.elastic_net_selection(X, y_vals, feature_names)
        scores['shap']     = self.shap_selection(X, y_vals, feature_names)
        scores['mi']       = self.mutual_info_selection(X, y_vals, feature_names)
        scores['pls']      = self.pls_selection(X, y_vals, feature_names)
        scores['granger']  = self.granger_selection(X_df, y)
        
        # Normalize each to [0,1]
        normalized = {}
        for method, score_series in scores.items():
            max_score = score_series.max()
            if max_score > 1e-10:
                normalized[method] = score_series / max_score
            else:
                normalized[method] = score_series
        
        # Weight methods by reliability
        # SHAP and ElasticNet get higher weight — better for collinear data
        method_weights = {
            'lasso':   0.15,
            'enet':    0.25,
            'shap':    0.25,
            'mi':      0.15,
            'pls':     0.15,
            'granger': 0.05,
        }
        
        # Compute weighted ensemble score
        ensemble_score = sum(
            normalized[method] * weight
            for method, weight in method_weights.items()
            if method in normalized
        )
        
        # Apply economic constraints based on bond type
        if bond_metadata:
            ensemble_score = self._apply_economic_constraints(
                ensemble_score, bond_metadata)
        
        # Select top factors
        ranked = ensemble_score.sort_values(ascending=False)
        selected = ranked.head(self.max_factors)
        
        # Compute agreement score: how many methods agree on each factor?
        agreement = pd.Series({
            factor: sum(
                1 for s in normalized.values() 
                if s.get(factor, 0) > 0.3
            )
            for factor in feature_names
        })
        
        return {
            'selected_factors':   selected.index.tolist(),
            'ensemble_scores':    ensemble_score.sort_values(ascending=False),
            'method_scores':      pd.DataFrame(normalized),
            'agreement':          agreement.sort_values(ascending=False),
            'n_methods_agree':    agreement[selected.index].to_dict(),
        }
    
    def _apply_economic_constraints(self, scores: pd.Series,
                                     bond_metadata: dict) -> pd.Series:
        """
        Boost/penalize factors based on bond fundamentals.
        A sovereign EM bond should load on CDX_EM, not CDX_IG.
        A US IG tech bond should load on CDX_IG and NDX, not EM FX.
        """
        
        scores = scores.copy()
        bond_type = bond_metadata.get('type', 'ig')
        sector    = bond_metadata.get('sector', 'unknown')
        country   = bond_metadata.get('country', 'US')
        rating    = bond_metadata.get('rating', 'BBB')
        
        # EM sovereign / corporate
        if country not in ['US', 'DE', 'FR', 'GB', 'JP']:
            for f in scores.index:
                if 'EM' in f or f in ['USDMXN', 'USDBRL', 'USDTRY']:
                    scores[f] *= 1.5
                if 'IG' in f and 'EM' not in f:
                    scores[f] *= 0.7
        
        # HY bonds
        if rating in ['BB', 'B', 'CCC'] or bond_type == 'hy':
            for f in scores.index:
                if 'HY' in f or f in ['HYG', 'JNK']:
                    scores[f] *= 1.4
                if f == 'VIX':
                    scores[f] *= 1.3
        
        # Energy sector
        if sector == 'energy':
            for f in scores.index:
                if f in ['OIL_WTI', 'OIL_BRENT', 'NATGAS']:
                    scores[f] *= 1.6
        
        # Financial sector — rates sensitive
        if sector == 'financials':
            for f in scores.index:
                if 'UST' in f or 'SWAP' in f or 'SLOPE' in f:
                    scores[f] *= 1.3
                if f in ['XLF']:
                    scores[f] *= 1.4
        
        return scores
